# --- Track 1: live execution (optional, not needed for Track 2) ---
BINANCE_LIVE_API_KEY=
BINANCE_LIVE_SECRET_KEY=
BINANCE_TESTNET_API_KEY=
BINANCE_TESTNET_SECRET_KEY=

# --- Telegram alerts (optional) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
