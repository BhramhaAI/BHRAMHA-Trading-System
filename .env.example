# BHRAMHA configuration template.
# Copy this file to `.env` and fill in your own keys. `.env` is gitignored.

# --- Track 2: CMC Skill + LLM (required for the strategy skill / backtester) ---
CMC_API_KEY=your_coinmarketcap_api_key_here
